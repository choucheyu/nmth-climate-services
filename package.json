{
  "name": "nmth-exhibition-climate-monitor",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:rbac:web": "pnpm --filter @nmth/web test -- permission floorPlanCallouts",
    "test:rbac:api": "pnpm --filter @nmth/api test -- rbac floor-plans alerts exhibitions",
    "test:rbac:e2e": "playwright test --config playwright.config.ts",
    "test:rbac": "pnpm test:rbac:web && pnpm test:rbac:api && pnpm test:rbac:e2e",
    "test:responsive": "playwright test apps/web/e2e/responsive-smoke.spec.ts --project=chromium --project=mobile --project=tablet",
    "prepush:rbac": "pnpm test:rbac",
    "format": "prettier --write .",
    "docker:config": "docker compose config",
    "db:validate": "pnpm --filter @nmth/api prisma:validate",
    "db:generate": "pnpm --filter @nmth/api prisma:generate",
    "db:migrate": "pnpm --filter @nmth/api prisma:migrate",
    "db:seed": "pnpm --filter @nmth/api prisma:seed"
  },
  "devDependencies": {
    "@eslint/js": "9.18.0",
    "@playwright/test": "1.60.0",
    "eslint": "9.18.0",
    "eslint-config-next": "15.5.18",
    "eslint-config-prettier": "9.1.0",
    "prettier": "3.4.2",
    "turbo": "2.3.3",
    "typescript": "5.7.3",
    "typescript-eslint": "8.20.0"
  },
  "pnpm": {
    "overrides": {
      "path-to-regexp": "8.4.2",
      "postcss": "8.5.15"
    }
  }
}

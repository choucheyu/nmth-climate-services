{
  "name": "@nmth/api",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/src/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "alerts:repair": "tsx src/alerts/repair-alerts.ts",
    "floor-plans:rendered-images": "tsx src/floor-plans/backfill-rendered-images.ts",
    "prisma:validate": "prisma validate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@napi-rs/canvas": "^1.0.0",
    "@nestjs/bullmq": "11.0.4",
    "@nestjs/common": "11.1.21",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.21",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.1.21",
    "@nestjs/swagger": "11.4.3",
    "@nmth/shared": "workspace:*",
    "@prisma/client": "6.2.1",
    "argon2": "0.41.1",
    "bullmq": "5.34.2",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "cookie-parser": "1.4.7",
    "exceljs": "4.4.0",
    "ioredis": "5.4.2",
    "multer": "2.1.1",
    "nanoid": "5.0.9",
    "nodemailer": "8.0.7",
    "passport": "0.7.0",
    "pdfjs-dist": "4.10.38",
    "pdfkit": "0.15.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.21",
    "@nestjs/schematics": "11.1.0",
    "@nestjs/testing": "11.1.21",
    "@types/cookie-parser": "1.4.8",
    "@types/express": "5.0.0",
    "@types/multer": "2.1.0",
    "@types/node": "22.10.5",
    "@types/nodemailer": "8.0.0",
    "@types/pdfkit": "0.13.5",
    "prisma": "6.2.1",
    "supertest": "7.0.0",
    "tsx": "4.19.2",
    "vitest": "2.1.8"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
